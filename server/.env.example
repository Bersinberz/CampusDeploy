PORT=4000
MONGO_URI=mongodb://localhost:27017/campusDeploy-db
CLIENT_ORIGIN=http://localhost:5173

# LLM Providers (tried in order, first success wins)
DEEPSEEK_API_KEY=nvapi-your-deepseek-key
KIMI_API_KEY=nvapi-your-kimi-key

# Remote server (where projects get deployed)
SERVER_IP=your.server.ip
SERVER_USER=root
SERVER_SSH_KEY_PATH=/path/to/your/private/key   # or leave blank and use SERVER_PASSWORD
SERVER_PASSWORD=                                  # used if SSH_KEY_PATH is empty
REMOTE_PROJECTS_DIR=/opt/campusdeploy/projects
